{
  "$schema": "https://mintlify.com/docs.json",
  "name": "2md",
  "theme": "venus",
  "colors": {
    "primary": "#8800ff",
    "light": "#8800ff",
    "dark": "#c084fc"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "appearance": {
    "strict": false,
    "default": "dark"
  },
  "background": {
    "color": {
      "dark": "#000000",
      "light": "#ffffff"
    }
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/traylinx/2md"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/traylinx/2md"
    }
  },
  "navigation": [
    {
      "group": "Get Started",
      "pages": [
        "introduction",
        "quickstart",
        "configuration"
      ]
    },
    {
      "group": "CLI",
      "pages": [
        "cli/overview",
        "cli/reference"
      ]
    },
    {
      "group": "Web UI",
      "pages": [
        "web-ui/convert",
        "web-ui/crawl",
        "web-ui/agentify",
        "web-ui/file2md"
      ]
    },
    {
      "group": "Deployment",
      "pages": [
        "deployment/architecture",
        "deployment/docker",
        "deployment/ci-cd"
      ]
    },
    {
      "group": "API Reference: Overview",
      "pages": [
        "api/overview"
      ]
    },
    {
      "group": "API Reference: Endpoints",
      "pages": [
        "api/convert",
        "api/crawl",
        "api/agentify",
        "api/file2md"
      ]
    }
  ]
}
