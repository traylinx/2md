# html2md Backend Production Environment Variables
# Copy this to .env (or configure in Coolify/Cloud Run) before starting the container

NODE_ENV=production
PORT=8222

# Storage location for the persistent jobs volume
JOBS_DIR=/data/jobs

# CORS Configuration (Comma-separated list of allowed frontend domains)
CORS_ORIGINS=https://2md.traylinx.com,https://www.2md.traylinx.com

# Integrations (Required for full functionality)
SWITCHAI_API_KEY=your_switchai_api_key_here
AGENTIFY_LLM_API_KEY=your_agentify_api_key_here

# Redis (BullMQ Async Queue - required for worker.js)
REDIS_URL=redis://127.0.0.1:6379

# Object Storage (AWS S3 — bucket already created)
# STORAGE_PROVIDER=s3
# S3_ENDPOINT=https://s3.eu-west-1.amazonaws.com
# S3_REGION=eu-west-1
# S3_BUCKET=2md-traylinx-production
# S3_ACCESS_KEY_ID=your_iam_access_key
# S3_SECRET_ACCESS_KEY=your_iam_secret_key
